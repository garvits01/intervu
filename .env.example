# ─────────────────────────────────────────────────────
# Haveloc Pro — Environment Variables
# Copy to .env.local and fill in values
# ─────────────────────────────────────────────────────

# ─── Database ───
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/haveloc_pro?schema=public"
REDIS_URL="redis://localhost:6379"

# ─── Auth0 ───
AUTH0_DOMAIN="your-tenant.auth0.com"
AUTH0_CLIENT_ID="your-client-id"
AUTH0_CLIENT_SECRET="your-client-secret"
AUTH0_AUDIENCE="https://api.haveloc.pro"
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── AI / LLM ───
OPENAI_API_KEY="sk-your-openai-key"
OPENAI_MODEL="gpt-4o"
AI_SERVICE_URL="http://localhost:8000"

# ─── AWS ───
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_S3_BUCKET="haveloc-pro-uploads"

# ─── App Config ───
NODE_ENV="development"
PORT=4000
WEB_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# ─── Kafka ───
KAFKA_BROKERS="localhost:9092"
KAFKA_CLIENT_ID="haveloc-pro"

# ─── Monitoring ───
SENTRY_DSN=""
DATADOG_API_KEY=""
