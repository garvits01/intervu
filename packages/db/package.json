{
    "name": "@haveloc/db",
    "version": "0.1.0",
    "private": true,
    "description": "Haveloc Pro database package — Prisma client and migrations",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "scripts": {
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:seed": "npx ts-node prisma/seed.ts",
        "db:setup": "prisma db push && npx ts-node prisma/seed.ts",
        "db:studio": "prisma studio",
        "build": "tsc",
        "clean": "rimraf dist",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/"
    },
    "dependencies": {
        "@prisma/client": "^6.3.0"
    },
    "devDependencies": {
        "prisma": "^6.3.0",
        "typescript": "^5.7.0",
        "rimraf": "^6.0.0"
    }
}