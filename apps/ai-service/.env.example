# ─────────────────────────────────────────────────────
# Haveloc Pro AI Service — Environment Variables
# ─────────────────────────────────────────────────────

# ─── App ───
APP_NAME="haveloc-pro-ai"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG=false
HOST="0.0.0.0"
PORT=8001
WORKERS=4
LOG_LEVEL="INFO"

# ─── Security ───
JWT_SECRET="change-me-in-production-use-256-bit-key"
JWT_ALGORITHM="HS256"
JWT_EXPIRY_MINUTES=60
API_KEYS="dev-key-1,dev-key-2"
CORS_ORIGINS="http://localhost:3000,http://localhost:4000"
RATE_LIMIT_PER_MINUTE=60

# ─── Database ───
DATABASE_URL="postgresql+asyncpg://haveloc:haveloc_dev@localhost:5432/haveloc_pro"
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Redis ───
REDIS_URL="redis://localhost:6379/0"
CACHE_TTL_SECONDS=300

# ─── AI / LLM ───
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-70b-versatile"
LLM_PROVIDER="auto"
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=30

# ─── Observability ───
OTEL_EXPORTER_ENDPOINT=""
PROMETHEUS_ENABLED=true
SENTRY_DSN=""

# ─── External ───
API_SERVICE_URL="http://localhost:4000"
WEBHOOK_SECRET=""
